# MISS CLOVER — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── Flask ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# ── Server (used by gunicorn / cloudflared) ───────────────────────
GUNICORN_BIND=127.0.0.1:5002
GUNICORN_LOGLEVEL=info

# ── Database ──────────────────────────────────────────────────────
# Default sqlite db lives at instance/missclover.db
DATABASE_URL=sqlite:///missclover.db

# ── Public URLs ───────────────────────────────────────────────────
# Used to build absolute links in emails (guest-order tracker, password reset)
SITE_URL=http://127.0.0.1:5002

# ── HitPay (Singapore payment gateway: cards / PayNow / GrabPay) ──
# Get sandbox keys at https://dashboard.sandbox.hit-pay.com/
HITPAY_API_KEY=
HITPAY_SALT=
# Use https://api.sandbox.hit-pay.com/v1 for sandbox, https://api.hit-pay.com/v1 for live
HITPAY_API_BASE=https://api.sandbox.hit-pay.com/v1
HITPAY_PAYMENT_METHODS=paynow_online,card,grabpay

# ── Mail (transactional email — order confirmation, password reset) ──
# Mailtrap.io credentials work fine for dev. Real SMTP in production.
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=hello@missclover.co

# ── Shipping (flat rate for now; SGD cents) ───────────────────────
SHIPPING_FLAT_RATE_CENTS=800
FREE_SHIPPING_THRESHOLD_CENTS=20000
